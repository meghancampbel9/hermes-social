# Hermes Social — copy to .env and fill in values

# Public URL of this instance (used in agent card and A2A routing)
HERMES_SOCIAL_EXTERNAL_URL=http://localhost:8340

# Identity shown in the agent card
HERMES_SOCIAL_AGENT_NAME=hermes-social
HERMES_SOCIAL_OWNER_NAME=User

# Secret for signing web auth JWTs — change this in production
HERMES_SOCIAL_JWT_SECRET=CHANGE-ME-IN-PRODUCTION
HERMES_SOCIAL_JWT_ALGORITHM=HS256
HERMES_SOCIAL_JWT_EXPIRE_MINUTES=10080  # 1 week

# Database (SQLite path or connection string)
HERMES_SOCIAL_DATABASE_URL=sqlite:///./data/hermes_social.db
HERMES_SOCIAL_DATA_DIR=./data

# MCP server (port 8341)
HERMES_SOCIAL_MCP_ENABLED=true

# Outbound A2A request tuning
HERMES_SOCIAL_AGENT_REQUEST_TIMEOUT=30
HERMES_SOCIAL_AGENT_RETRY_ATTEMPTS=3
HERMES_SOCIAL_AGENT_RETRY_BASE_DELAY=2.0

# Webhook fired to host agent on new inbound messages
HERMES_SOCIAL_NOTIFICATION_WEBHOOK_URL=
HERMES_SOCIAL_NOTIFICATION_WEBHOOK_SECRET=