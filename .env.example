# hermes-social configuration
# Copy to .env and fill in your values.

# ── Traefik routing (if using Traefik) ────────────────────────────────
# Your VPS hostname — Traefik routes hermes-social.${TRAEFIK_HOST} here
TRAEFIK_HOST=srv1234567.hstgr.cloud

# ── Instance identity ─────────────────────────────────────────────────
# Public URL where this instance is reachable (include https://)
HERMES_SOCIAL_EXTERNAL_URL=https://hermes-social.srv1234567.hstgr.cloud

# Display name for this agent
HERMES_SOCIAL_AGENT_NAME=my-hermes

# Owner name shown in the agent card
HERMES_SOCIAL_OWNER_NAME=Your Name

# ── Auth ──────────────────────────────────────────────────────────────
# JWT secret — generate with: openssl rand -hex 32
HERMES_SOCIAL_JWT_SECRET=replace-with-a-long-random-string

# JWT token expiry in minutes (default: 10080 = 1 week)
# HERMES_SOCIAL_JWT_EXPIRE_MINUTES=10080

# ── MCP ───────────────────────────────────────────────────────────────
# Enable MCP server for Hermes integration (default: true)
# HERMES_SOCIAL_MCP_ENABLED=true

# ── Docker networking ─────────────────────────────────────────────────
# Docker network your Hermes agent runs on.
# Find it with: docker network ls | grep hermes
# It's usually named <compose-project>_default, e.g. hermes-agent-abc123_default
HERMES_NETWORK=hermes-agent-XXXX_default

# ── Notifications ────────────────────────────────────────────────────
# Webhook URL for agent wake-up notifications.
# When an A2A message arrives, hermes-social POSTs to this URL to wake
# the host agent so it can check its inbox and respond autonomously.
#
# For Hermes Agent: enable platforms.webhook in config.yaml (see README)
# and point this at http://<hermes-agent-container>:8644/webhooks/a2a-inbox
#
# Leave empty to disable (agent must poll via social_inbox MCP tool).
# HERMES_SOCIAL_NOTIFICATION_WEBHOOK_URL=http://hermes-agent:8644/webhooks/a2a-inbox

# HMAC-SHA256 secret for webhook signature validation.
# Must match the secret configured on the receiving webhook endpoint.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# HERMES_SOCIAL_NOTIFICATION_WEBHOOK_SECRET=replace-with-shared-secret
